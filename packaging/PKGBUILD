# Maintainer: Sihyung Lee <sh__lv@naver.com>

pkgname=blear-git
_pkgname=blear
pkgrel=1
pkgver=f60b2a5
pkgdesc="clears the terminal and move the prompt to the bottom of the screen"
url="https://github.com/asdfer-1234/blear"
source=("git+https://github.com/asdfer-1234/blear")
arch=('x86_64')
license=('GPL3')
makedepends=('cargo')
provides=('blear')
sha256sums=(SKIP)

build() {
	cd "$srcdir/$_pkgname"
	cargo build --release
}

package() {
	cd "$srcdir/$pkgname"
	install -Dm755 target/release/blear "${pkgdir}/usr/bin/blear"
}

pkgver() {
	cd "$srcdir/$_pkgname"
	git describe --always
}
